{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index?route=$1"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15
    }
  }
}
