{
  "name": "gmt-homes-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch api --watch src --watch data --watch ../shared --ext ts,json --legacy-watch --signal SIGTERM --exec \"node --import tsx src/index.ts\"",
    "build": "tsc --noEmit -p tsconfig.json",
    "start": "node --import tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "node --import tsx src/scripts/db.ts migrate",
    "db:status": "node --import tsx src/scripts/db.ts status",
    "db:summary": "node --import tsx src/scripts/db.ts summary",
    "db:import-legacy-auth": "node --import tsx src/scripts/db.ts import-legacy-auth",
    "db:make-admin": "node --import tsx src/scripts/db.ts make-admin"
  },
  "dependencies": {
    "nodemailer": "^8.0.4",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
