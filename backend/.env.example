HOST=127.0.0.1
PORT=4000
SITE_URL=https://your-domain.com
BACKEND_SERVICE_TOKEN=replace-this-with-a-shared-service-token
# The backend can create this local PostgreSQL database automatically on first boot.
DATABASE_URL=postgresql://postgres:1414@localhost:5432/GMT%20Homes
# Mirror these if you want the backend capability endpoint to report upload support.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
PASSWORD_RESET_SMTP_HOST=smtp.example.com
PASSWORD_RESET_SMTP_PORT=587
PASSWORD_RESET_SMTP_USER=mailer@example.com
PASSWORD_RESET_SMTP_PASS=replace-with-mail-password
PASSWORD_RESET_SMTP_SECURE=false
PASSWORD_RESET_FROM_EMAIL=GMT Homes <no-reply@example.com>
# Set to true only if you want production to display a one-time reset link on screen
# when SMTP is not configured yet.
PASSWORD_RESET_SHOW_LINK_FALLBACK=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
GMT_HOMES_COMPANY_NAME=GMT Homes
GMT_HOMES_CONTACT_EMAIL=hello@gmthomes.co
GMT_HOMES_CONTACT_PHONE=+234 803 520 8600
GMT_HOMES_CONTACT_NAME=Grace Olanrewaju
GMT_HOMES_CONTACT_INITIALS=GO
GMT_HOMES_CONTACT_ROLE=Lead Property Advisor
GMT_HOMES_CONTACT_RESPONSE_TIME=Usually responds within 20 minutes
GMT_HOMES_LISTING_RESPONSE_TIME=Usually responds within 30 minutes
